def log_subprocess(cmd: list[str], description: str) -> tuple[int, str, str]:
    """Run a subprocess with logging."""
    print(f"    Running: {description}")
    print(f"      Command: {' '.join(cmd[:4])}... (truncated)")
    start = time.time()
    result = subprocess.run(cmd, capture_output=True, text=True, check=False)
    elapsed = time.time() - start
    print(f"      Completed in {elapsed:.2f}s (exit code: {result.returncode})")
    return result.returncode, result.stdout, result.stderr


def reset_terminal():
    try:
        subprocess.run(["stty", "sane"], check=False, stderr=subprocess.DEVNULL)
    except Exception:
        pass


atexit.register(reset_terminal)


def signal_handler(sig: int, frame: Any) -> None:
    print("\n\nInterrupted. Exiting...")
    reset_terminal()
    sys.exit(0)


signal.signal(signal.SIGINT, signal_handler)


def get_user_confirmation(prompt: str) -> bool:
    reset_terminal()
    try:
        return input(prompt).strip().lower() in ["y", "yes"]
    except KeyboardInterrupt:
        reset_terminal()
        return False


def format_eta(seconds: float) -> str:
    if seconds < 0:
        return "calculating..."
    if seconds < 60:
        return f"{seconds:.0f}s"
    if seconds < 3600:
        minutes = int(seconds // 60)
        secs = int(seconds % 60)
        return f"{minutes}m {secs}s"
    hours = int(seconds // 3600)
    minutes = int((seconds % 3600) // 60)
    return f"{hours}h {minutes}m"


def check_gpu_availability() -> dict[str, bool]:
    gpus: dict[str, bool] = {"intel": False, "nvidia": False}
    try:
        print("  Checking GPU availability with ffmpeg -encoders...")
        result = subprocess.run(
            ["ffmpeg", "-encoders"], capture_output=True, text=True, check=False
        )
        if "hevc_nvenc" in result.stdout:
            gpus["nvidia"] = True
            print("    NVIDIA NVENC (HEVC) available")
        if "hevc_qsv" in result.stdout:
            gpus["intel"] = True
            print("    Intel QSV (HEVC) available")
    except (subprocess.SubprocessError, FileNotFoundError):
        pass

    if not gpus["nvidia"]:
        try:
            print("    Checking NVIDIA with nvidia-smi...")
            result = subprocess.run(
                ["nvidia-smi"], capture_output=True, text=True, check=False
            )
            if result.returncode == 0:
                gpus["nvidia"] = True
                print("    NVIDIA GPU detected via nvidia-smi")
        except (subprocess.SubprocessError, FileNotFoundError):
            pass
    return gpus


def get_file_stem(filepath: Path) -> str:
