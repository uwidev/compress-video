def get_extension(filepath: Path) -> str:
    return filepath.suffix.lower()


def is_lossless(filepath: Path) -> bool:
    """Check if a video file is lossless."""
    try:
        # First check: look for lossless flag
        print(f"    Checking lossless status with ffprobe: {filepath.name}")
        cmd = [
            "ffprobe",
            "-v",
            "error",
            "-select_streams",
            "v:0",
            "-show_entries",
            "frame=lossless",
            "-of",
            "default=noprint_wrappers=1",
            str(filepath),
        ]
        result = subprocess.run(cmd, capture_output=True, text=True, check=False)
        if "lossless=1" in result.stdout:
            print(f"    -> File is lossless (flag detected)")
            return True

        # Fallback: check codec/pix_fmt (this is faster)
        print(f"    Checking codec/pix_fmt with ffprobe: {filepath.name}")
        cmd2 = [
            "ffprobe",
            "-v",
            "error",
            "-select_streams",
            "v:0",
            "-show_entries",
            "stream=codec_name,pix_fmt",
            "-of",
            "json",
            str(filepath),
        ]
        result2 = subprocess.run(cmd2, capture_output=True, text=True, check=False)
        if result2.returncode == 0:
            data = json.loads(result2.stdout)
            if "streams" in data and data["streams"]:
                stream = data["streams"][0]
                codec = stream.get("codec_name", "").lower()
                lossless_codecs = [
                    "ffv1",
                    "ffvhuff",
                    "huffyuv",
                    "png",
                    "qtrle",
                    "rle",
                    "utvideo",
                    "v210",
                    "v308",
                    "v408",
                    "v410",
                    "yuv4",
                ]
                if codec in lossless_codecs:
                    print(f"    -> File is lossless (codec {codec})")
                    return True
        print(f"    -> File is lossy")
        return False
    except (subprocess.SubprocessError, json.JSONDecodeError, KeyError):
        print(f"    -> Error checking lossless status")
        return False


def analyze_source(filepath: Path) -> dict[str, Any]:
    try:
        print(f"    Analyzing source with ffprobe: {filepath.name}")
        cmd = [
            "ffprobe",
            "-v",
            "error",
            "-select_streams",
            "v:0",
            "-show_entries",
            "stream=codec_name,pix_fmt,width,height,bit_rate",
            "-show_entries",
            "format=duration,size,bit_rate",
            "-of",
            "json",
            str(filepath),
        ]
        result = subprocess.run(cmd, capture_output=True, text=True, check=False)
        if result.returncode != 0:
            return {}
        data = json.loads(result.stdout)
        info: dict[str, Any] = {}
        if "streams" in data and data["streams"]:
            stream = data["streams"][0]
            info["codec"] = stream.get("codec_name", "unknown")
            info["pix_fmt"] = stream.get("pix_fmt", "unknown")
            info["width"] = int(stream.get("width", 0))
            info["height"] = int(stream.get("height", 0))
            info["bit_rate"] = int(stream.get("bit_rate", 0))
        if "format" in data:
            info["duration"] = float(data["format"].get("duration", 0))
            info["size"] = int(data["format"].get("size", 0))
            if info.get("bit_rate", 0) == 0:
                info["bit_rate"] = int(data["format"].get("bit_rate", 0))
        print(f"    Analysis complete: {info.get('codec', 'unknown')} @ {info.get('width', 0)}x{info.get('height', 0)}")
        return info
    except (subprocess.SubprocessError, json.JSONDecodeError, KeyError, ValueError):
        print(f"    Error analyzing source")
        return {}


def is_audio_lossless(filepath: Path) -> bool:
    try:
        print(f"    Checking audio lossless with ffprobe: {filepath.name}")
        cmd = [
            "ffprobe",
            "-v",
            "error",
            "-select_streams",
            "a:0",
            "-show_entries",
            "stream=codec_name",
            "-of",
            "default=noprint_wrappers=1:nokey=1",
            str(filepath),
        ]
        result = subprocess.run(cmd, capture_output=True, text=True, check=False)
        if result.returncode != 0:
            return False
        codec = result.stdout.strip().lower()
        lossless_codecs = [
            "flac",
            "pcm_s16le",
            "pcm_s24le",
            "pcm_s32le",
            "alac",
            "wav",
            "pcm_f32le",
            "pcm_f64le",
            "pcm_s16be",
            "pcm_s24be",
            "pcm_s32be",
        ]
        result_bool = codec in lossless_codecs
        print(f"    Audio is {'lossless' if result_bool else 'lossy'} ({codec})")
        return result_bool
    except subprocess.SubprocessError:
        print(f"    Error checking audio lossless")
        return False


