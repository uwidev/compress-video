        "-force_key_frames",
        "expr:eq(n,0)",
        "-loop",
        "0",
        "-y",
        str(output_path),
    ]
    _add_audio_options(cmd, has_audio, actual_audio)
    return cmd


def _copy_fallback(
    input_path: Path, output_path: Path, has_audio: bool, actual_audio: str | None
) -> tuple[bool, str]:
    try:
        print(f"    Copying original file to: {output_path}")
        output_path.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(input_path, output_path)
        size = output_path.stat().st_size
        return True, f"COPIED (original): {size / 1024 / 1024:.2f}MB"
    except Exception as e:
        return False, f"COPY FAILED: {str(e)[:100]}"


def _add_audio_options(
    cmd: list[str], has_audio: bool, actual_audio: str | None
) -> None:
    if not has_audio or not actual_audio:
        return
    if actual_audio == "copy":
        cmd.insert(3, "-c:a")
        cmd.insert(4, "copy")
    elif actual_audio == "flac":
        cmd.insert(3, "-c:a")
        cmd.insert(4, "flac")
    elif actual_audio == "aac":
        cmd.insert(3, "-c:a")
        cmd.insert(4, "aac")
        cmd.insert(5, "-b:a")
        cmd.insert(6, "192k")
    elif actual_audio == "opus":
        cmd.insert(3, "-c:a")
        cmd.insert(4, "libopus")
        cmd.insert(5, "-b:a")
        cmd.insert(6, "128k")


def find_media_files(root_dir: Path) -> tuple[dict[str, dict[str, Path]], list[Path]]:
    media_map: dict[str, dict[str, Path]] = defaultdict(dict)
    non_media: list[Path] = []
    if not root_dir.exists():
        print(f"Error: Directory {root_dir} does not exist")
        sys.exit(1)
    print("Scanning directory...")
    count = 0
    for filepath in root_dir.rglob("*"):
        if not filepath.is_file():
            continue
        count += 1
        if count % 1000 == 0:
            print(f"  Scanned {count} files...")
        ext = get_extension(filepath)
        if ext in MEDIA_EXTENSIONS:
            media_map[get_file_stem(filepath)][ext] = filepath
        else:
            non_media.append(filepath)
    print(f"  Done scanning {count} files")
    return media_map, non_media


def resolve_media_conflicts(
    media_map: dict[str, dict[str, Path]],
) -> tuple[dict[Path, Path], list[Path]]:
    conversion_map: dict[Path, Path] = {}
    skipped_gifs: list[Path] = []
    priority = {".mov": 0, ".mp4": 1, ".mkv": 2, ".avi": 3, ".webm": 4, ".m4v": 5}
    for stem, ext_dict in media_map.items():
        has_video = any(ext in VIDEO_PRIORITY for ext in ext_dict)
        has_gif = ".gif" in ext_dict
        if has_video and has_gif:
            video_ext = sorted(
                [e for e in ext_dict if e in VIDEO_PRIORITY],
                key=lambda x: priority.get(x, 999),
            )[0]
            conversion_map[ext_dict[video_ext]] = ext_dict[video_ext]
            skipped_gifs.append(ext_dict[".gif"])
        else:
            for path in ext_dict.values():
                conversion_map[path] = path
    return conversion_map, skipped_gifs


def copy_non_media_files(
    src_root: Path, dst_root: Path, files: list[Path], dry_run: bool = False
) -> None:
    if not files:
        return
    print("\nCopying non-media files...")
    copied = 0
    for filepath in files:
        rel = filepath.relative_to(src_root)
        dst = dst_root / rel
        if not dry_run:
            dst.parent.mkdir(parents=True, exist_ok=True)
            shutil.copy2(filepath, dst)
            copied += 1
            if copied % 50 == 0:
                print(f"  Copied {copied}/{len(files)}")
    print(f"  Done copying {copied} files")


def probe_files_batch(filepaths: list[Path]) -> dict[Path, dict[str, float | int]]:
    """Probe multiple files in a single ffprobe call using -print_filename."""
    if not filepaths:
        return {}

    try:
        print(f"  Probing {len(filepaths)} files in single ffprobe call...")
        start = time.time()

        # Build command: ffprobe with -print_filename to get filename per entry
        cmd = [
            "ffprobe",
            "-v",
            "error",
            "-show_entries",
            "format=duration,size",
            "-of",
            "default=noprint_wrappers=1:nokey=1",
            "-print_filename",
        ]
        # Add all file paths
        cmd.extend(str(p) for p in filepaths)

        result = subprocess.run(cmd, capture_output=True, text=True, check=False)
        elapsed = time.time() - start
        print(f"    ffprobe completed in {elapsed:.2f}s")

        if result.returncode != 0:
            print(f"    ffprobe failed: {result.stderr[:200]}")
            return {}

        # Parse output: format is filename on one line, then duration, then size
        lines = result.stdout.splitlines()
        results = {}
        i = 0
        while i < len(lines):
            if i + 2 >= len(lines):
                break
            # The first line is filename (with possible quotes)
            filename = lines[i].strip()
            # Remove quotes if present
            if filename.startswith('"') and filename.endswith('"'):
                filename = filename[1:-1]
            path = Path(filename)
            duration_str = lines[i+1].strip()
            size_str = lines[i+2].strip()
            try:
                duration = float(duration_str)
                size = int(size_str)
                results[path] = {"duration": duration, "size": size}
            except ValueError:
                # skip invalid entries
                pass
            i += 3

        return results
    except (subprocess.SubprocessError, Exception) as e:
        print(f"    ffprobe batch error: {e}")
        return {}


def is_output_complete(input_path: Path, output_path: Path) -> bool:
    # This function is kept for backwards compatibility, but the batch version is used in pre-scan.
    # It now uses a single ffprobe call for the pair.
    if not output_path.exists() or output_path.stat().st_size == 0:
        return False

    try:
        print(f"    Probing durations with ffprobe (single call)...")
        start = time.time()
        cmd = [
            "ffprobe",
            "-v",
            "error",
            "-show_entries",
            "format=duration",
            "-of",
            "default=noprint_wrappers=1:nokey=1",
            str(input_path),
            str(output_path),
        ]
        result = subprocess.run(cmd, capture_output=True, text=True, check=False)
        elapsed = time.time() - start
        print(f"      ffprobe completed in {elapsed:.2f}s")

        if result.returncode != 0:
            return False
        durations = result.stdout.strip().splitlines()
        if len(durations) < 2:
            return False
        dur_in = float(durations[0])
        dur_out = float(durations[1])
        if dur_in == 0:
            return False
        ratio = dur_out / dur_in
        print(f"    Duration match: {dur_out:.2f}s / {dur_in:.2f}s = {ratio:.3f} -> {'OK' if 0.99 <= ratio <= 1.01 else 'FAIL'}")
        return 0.99 <= ratio <= 1.01
    except (subprocess.SubprocessError, ValueError):
        return False


def determine_encoding_strategy(
    input_path: Path, force_strategy: str | None = None
) -> str:
    if force_strategy:
        return force_strategy
    return "lossless" if is_lossless(input_path) else "transparent"


def process_file(
    input_path: Path,
    src_root: Path | None,
    dst_root: Path | None,
    gpu: str,
    dry_run: bool,
    quality: int,
    strategy: str | None = None,
    audio: str = "auto",
    force: bool = False,
    fast_resume: bool = False,
    output_suffix: str = "-compressed",
) -> tuple[Path, bool, str, str, Path, str, int]:
    global processed_files, processed_bytes

    actual_strategy = determine_encoding_strategy(input_path, strategy)
    if src_root is not None:
        rel = input_path.relative_to(src_root)
        output_path = dst_root / rel.with_suffix(".mkv")
        display_name = str(rel)
    else:
        display_name = input_path.name
        output_path = input_path.parent / (input_path.stem + output_suffix + ".mkv")

    file_size = input_path.stat().st_size

    # Resume check
    if not force:
        if fast_resume:
            if output_path.exists():
                if dry_run:
                    print(f"  [RESUME] Would skip: {display_name} (output exists)")
                else:
                    print(f"  [RESUME] Skipping: {display_name} (output exists)")
                return (
                    input_path,
                    True,
                    "SKIPPED (output exists)",
                    gpu,
                    output_path,
                    actual_strategy,
                    0,
                )
        else:
            if is_output_complete(input_path, output_path):
                if dry_run:
                    print(f"  [RESUME] Would skip: {display_name} (output complete)")
                else:
                    print(f"  [RESUME] Skipping: {display_name} (output complete)")
                return (
                    input_path,
                    True,
                    "SKIPPED (complete)",
                    gpu,
                    output_path,
                    actual_strategy,
                    0,
                )

    # Log the start of encoding
    if not dry_run:
        print(f"  Processing: {display_name} ({file_size / 1024 / 1024:.2f} MB) - {actual_strategy}")

    output_path.parent.mkdir(parents=True, exist_ok=True)
    success, status = convert_with_ffmpeg(
        input_path, output_path, gpu, dry_run, actual_strategy, quality, audio
    )

    if not success and not dry_run:
        with failed_files_lock:
            failed_files_list.append((input_path, status))

    if not dry_run and not status.startswith("SKIPPED"):
        with eta_lock:
            processed_files += 1
            processed_bytes += file_size

    return input_path, success, status, gpu, output_path, actual_strategy, file_size


def format_conversion_line(
    input_path: Path,
    output_path: Path,
    gpu: str,
    strategy: str,
    src_root: Path | None,
    dst_root: Path | None,
    status: str | None = None,
) -> str:
    if src_root is not None:
        rel_in = str(input_path.relative_to(src_root))
        rel_out = (
            str(output_path.relative_to(dst_root)) if dst_root else output_path.name
        )
    else:
        rel_in = input_path.name
        rel_out = output_path.name
    gpu_name = get_gpu_name(gpu)
    label = strategy.upper()
    prefix = f"[{gpu_name} {label}] CONVERT: "
    if src_root:
        line = f"{prefix}{src_root.name}/{rel_in}\n"
        diff = len(prefix) + len(src_root.name) - len(dst_root.name) if dst_root else 0
        line += (
            f"{' ' * (diff - 2)}➥ {dst_root.name}/{rel_out}"
            if dst_root
            else f"{' ' * (len(prefix))}➥ {rel_out}"
        )
    else:
        line = f"{prefix}{rel_in}\n"
        line += f"{' ' * (len(prefix))}➥ {rel_out}"
    if status:
        line += f" - {status}"
    return line


def build_file_list(args: list[str]) -> tuple[list[Path], bool]:
    """
    Parse arguments: if exactly one arg and it's a directory, return directory mode.
    Otherwise, treat all args as files.
    Returns (files_or_root, is_directory_mode).
    """
    paths = [Path(a).resolve() for a in args]
    # If only one argument and it's a directory, treat as directory mode.
    if len(paths) == 1 and paths[0].is_dir():
        return paths, True
    # Otherwise, treat as file list (filter out directories? we'll error if directory is mixed)
    for p in paths:
        if p.is_dir():
            print(
                f"Error: When specifying multiple inputs, directories are not allowed (found: {p})"
            )
            sys.exit(1)
    return paths, False


def process_items(
    items: list[Path] | Path,
    dst_root: Path | None,
    dry_run: bool,
    use_intel: bool,
    use_nvidia: bool,
    nvidia_workers: int,
    intel_workers: int,
    cpu_workers: int,
    quality: int,
    strategy: str | None,
    audio: str,
    force: bool,
    fast_resume: bool,
    is_directory: bool,
) -> dict:
    """Unified processing for both directory and file lists."""
    global total_bytes_to_encode, processed_bytes, processed_files, start_time
    global converted_count, failed_count, skipped_count
    global total_input_bytes, total_output_bytes

    print("\nDetecting available hardware...")
    gpus = check_gpu_availability()
    available: list[str] = []
    if use_nvidia and gpus["nvidia"]:
        available.append("nvidia")
    if use_intel and gpus["intel"]:
        available.append("intel")
    if not available:
        available.append("cpu")

    print(f"\n✅ Selected encoders: {', '.join(get_gpu_name(g) for g in available)}")
    print("\n⚙️ Settings:")
    print(f"  Strategy: {'auto-detect' if strategy is None else strategy}")
    print(f"  Quality: {quality} (1=best, 15=transparent, 30=smaller)")
    print(f"  Audio: {audio}")
    print(f"  Force re-encode: {'YES' if force else 'NO'}")
    print(
        f"  Workers: NVIDIA={nvidia_workers}, Intel={intel_workers}, CPU={cpu_workers}"
    )
    print()

    if is_directory:
        # Directory mode: scan and build conversion_map
        print("Scanning for media files...")
        media_map, non_media = find_media_files(items[0])
        print(f"  Found {len(media_map)} unique media files (by stem).")
        print("Resolving conflicts between GIF and video files...")
        conversion_map, skipped_gifs = resolve_media_conflicts(media_map)
        if skipped_gifs:
            print(f"  Skipped {len(skipped_gifs)} GIF files (video version exists).")
        src_root = items[0]
        dst_root = dst_root or Path(f"{src_root}-compressed")
    else:
        # File mode: each file is a media file; no conflict resolution
        print("Processing individual files...")
        conversion_map = {p: p for p in items}
        skipped_gifs = []
        non_media = []
        src_root = None
        dst_root = None  # will be set per file in process_file

    print(f"  Total media files to process: {len(conversion_map)}")
    print()

    # ---- Pre‑scan for resume (batched ffprobe) ----
    files_to_encode: list[Path] = []
    total_bytes: int = 0
    skipped_existing: int = 0

    print("Checking for existing output files (resume)...")
    total_items = len(conversion_map)

    if not force:
        # Build list of (input_path, output_path) pairs
        probe_pairs: list[tuple[Path, Path]] = []
        for input_path in conversion_map.keys():
            if is_directory:
                rel = input_path.relative_to(src_root)
                out = dst_root / rel.with_suffix(".mkv")
            else:
                out = input_path.parent / (input_path.stem + "-compressed.mkv")
            probe_pairs.append((input_path, out))

        # Separate files that need probing (output exists)
        all_files_to_probe: list[Path] = []
        for inp, out in probe_pairs:
            if out.exists() and out.stat().st_size > 0:
                all_files_to_probe.append(inp)
                all_files_to_probe.append(out)

        if all_files_to_probe:
            # Probe all files in one ffprobe call
            probe_results = probe_files_batch(all_files_to_probe)
            if probe_results:
                # Now check each pair
                for inp, out in probe_pairs:
                    if out.exists() and out.stat().st_size > 0:
                        if inp in probe_results and out in probe_results:
                            dur_in = probe_results[inp]["duration"]
                            dur_out = probe_results[out]["duration"]
                            if dur_in > 0 and 0.99 <= dur_out / dur_in <= 1.01:
                                skipped_existing += 1
                                total_input_bytes += inp.stat().st_size
                                total_output_bytes += out.stat().st_size
                                continue
                    files_to_encode.append(inp)
                    total_bytes += inp.stat().st_size
            else:
                # Fallback to individual checks if batch failed
                print("  Batch ffprobe failed, falling back to individual checks...")
                for inp, out in probe_pairs:
                    if out.exists() and out.stat().st_size > 0:
                        if is_output_complete(inp, out):
                            skipped_existing += 1
                            total_input_bytes += inp.stat().st_size
                            total_output_bytes += out.stat().st_size
                            continue
                    files_to_encode.append(inp)
                    total_bytes += inp.stat().st_size
        else:
            # No files to probe, all need encoding
            for inp, out in probe_pairs:
                files_to_encode.append(inp)
                total_bytes += inp.stat().st_size
    else:
        for input_path in conversion_map.keys():
            files_to_encode.append(input_path)
            total_bytes += input_path.stat().st_size
        print(f"  Force mode: all {len(files_to_encode)} files will be re-encoded")

    print("\n  Pre-scan complete:")
    print(
        f"  • {len(files_to_encode)} files need encoding ({total_bytes / 1024 / 1024 / 1024:.2f} GB)"
    )
    print(f"  • {skipped_existing} files already complete (will be skipped)")
    if skipped_existing > 0:
        estimated_minutes = (skipped_existing * 30) / 60
        print(
            f"  • Resume will save ~{estimated_minutes:.1f} minutes of encoding time (estimated)"
        )
    total_bytes_to_encode = total_bytes
    print()

    if dry_run:
        print("--- DRY RUN: Sample files to convert (first 20) ---\n")
        for i, inp in enumerate(files_to_encode[:20]):
            if is_directory:
                out = dst_root / inp.relative_to(src_root).with_suffix(".mkv")
            else:
                out = inp.parent / (inp.stem + "-compressed.mkv")
            strat = determine_encoding_strategy(inp, strategy)
            gpu_display = available[0] if available else "cpu"
            print(
                format_conversion_line(
                    inp,
                    out,
                    gpu_display,
                    strat,
                    src_root,
                    dst_root if is_directory else None,
                )
            )
            print()
        if len(files_to_encode) > 20:
            print(f"  ... and {len(files_to_encode) - 20} more files\n")
        if skipped_gifs:
            print("Skipped GIFs (video version will be used instead):")
            for gif in skipped_gifs[:10]:
                print(
                    f"  SKIP: {gif.relative_to(src_root) if is_directory else gif.name}"
                )
            if len(skipped_gifs) > 10:
                print(f"  ... and {len(skipped_gifs) - 10} more")
        return {
            "converted": 0,
            "failed": 0,
            "skipped": skipped_existing,
            "non_media": len(non_media) if is_directory else 0,
            "skipped_gifs": len(skipped_gifs),
        }

    # ---- Shared queue ----
    print(f"Starting encoding of {len(files_to_encode)} files using {len(available)} encoder(s)...")
    file_queue: queue.Queue = queue.Queue()
    for f in files_to_encode:
        file_queue.put(f)

    total_files = len(files_to_encode)
    processed_files = 0
    processed_bytes = 0
    start_time = time.time()
    converted_count = 0
    failed_count = 0
    skipped_count = 0

    def worker_loop(gpu: str) -> None:
        nonlocal total_files
        while True:
            try:
                inp = file_queue.get(timeout=0.5)
            except queue.Empty:
                break
            try:
                result = process_file(
                    inp,
                    src_root,
                    dst_root if is_directory else None,
                    gpu,
                    dry_run,
                    quality,
                    strategy,
                    audio,
                    force,
                    fast_resume,
                )
                with summary_lock:
                    global converted_count, failed_count, skipped_count
                    global total_input_bytes, total_output_bytes
                    inp, success, status, gpu_used, out, strat, fsize = result

                    if status.startswith("SKIPPED"):
                        skipped_count += 1
                    elif success:
                        converted_count += 1
                        total_input_bytes += inp.stat().st_size
                        total_output_bytes += out.stat().st_size
                        if status and not status.startswith("DONE"):
                            rel = (
                                inp.relative_to(src_root) if is_directory else inp.name
                            )
                            print(f"  [{get_gpu_name(gpu_used)}] ✓ {rel} -> {status}")
                    else:
                        failed_count += 1
                        rel = inp.relative_to(src_root) if is_directory else inp.name
                        print(
                            f"  [{get_gpu_name(gpu_used)}] ✗ FAILED: {rel} - {status}"
                        )
            except Exception as e:
                print(f"  Worker for {gpu} crashed on {inp}: {e}")
            finally:
                file_queue.task_done()

    # ---- Start threads ----
    threads: list[threading.Thread] = []
    if "nvidia" in available:
        for _ in range(nvidia_workers):
            t = threading.Thread(target=worker_loop, args=("nvidia",))
            t.start()
            threads.append(t)
    if "intel" in available:
        for _ in range(intel_workers):
            t = threading.Thread(target=worker_loop, args=("intel",))
            t.start()
            threads.append(t)
    if "cpu" in available:
        for _ in range(cpu_workers):
            t = threading.Thread(target=worker_loop, args=("cpu",))
            t.start()
            threads.append(t)

    file_queue.join()
    for t in threads:
        t.join()

    print(f"\n  Completed all {total_files} files")

    # ---- Copy non‑media files (only in directory mode) ----
    if is_directory and non_media:
        copy_non_media_files(src_root, dst_root, non_media, dry_run)

    # ---- Summary ----
    print("\n" + "=" * 50)
    print("SUMMARY")
    print("=" * 50)
    print(f"Converted: {converted_count}")
    print(f"Failed: {failed_count}")
    print(f"Skipped (already complete): {skipped_count}")
    if is_directory:
        print(f"Skipped GIFs (video exists): {len(skipped_gifs)}")
        print(f"Non-media copied: {len(non_media)}")
    else:
        print(f"Files processed: {len(conversion_map)}")

    if failed_files_list:
        print("\n" + "=" * 50)
        print("FAILED FILES")
        print("=" * 50)
        print(f"Total failures: {len(failed_files_list)}")
        print()
        for i, (filepath, error) in enumerate(failed_files_list[:20]):
            rel = filepath.relative_to(src_root) if is_directory else filepath.name
            error_short = error[:200] + "..." if len(error) > 200 else error
            print(f"  {i + 1}. {rel}")
            print(f"     Error: {error_short}")
            print()
        if len(failed_files_list) > 20:
            print(f"  ... and {len(failed_files_list) - 20} more failures")
            if is_directory:
                print(f"  Full list saved to: {dst_root}/failed_files.txt")
        if not dry_run and is_directory:
            fail_log = dst_root / "failed_files.txt"
            with open(fail_log, "w") as f:
                f.write(f"Failed files ({len(failed_files_list)} total)\n")
                f.write("=" * 60 + "\n\n")
                for filepath, error in failed_files_list:
                    rel = (
                        filepath.relative_to(src_root)
                        if is_directory
                        else filepath.name
                    )
                    f.write(f"File: {rel}\n")
                    f.write(f"Error: {error}\n")
                    f.write("-" * 40 + "\n")
            print(f"  Full failure log: {fail_log}")

    if total_input_bytes > 0 and total_output_bytes > 0:
        reduction = (1 - (total_output_bytes / total_input_bytes)) * 100
        print("\n" + "=" * 50)
        print("COMPRESSION STATISTICS")
        print("=" * 50)
        print(f"Total input size:  {total_input_bytes / 1024 / 1024 / 1024:.2f} GB")
        print(f"Total output size: {total_output_bytes / 1024 / 1024 / 1024:.2f} GB")
        print(
            f"Space saved:       {total_input_bytes / 1024 / 1024 / 1024 - total_output_bytes / 1024 / 1024 / 1024:.2f} GB ({reduction:.1f}% reduction)"
        )
        if converted_count > 0:
            print(f"Files encoded:     {converted_count} files")
        if skipped_count > 0:
            print(f"Files skipped:     {skipped_count} files (already complete)")

    print("\n⚠️  Notes:")
    print("  • Animation-optimized HEVC encoding (quality 15)")
    print("  • Loop-optimized: -bf 0 -g 99999 -force_key_frames expr:eq(n,0)")
    print("  • Dynamic load balancing: faster GPUs process more files")

    return {
        "converted": converted_count,
        "failed": failed_count,
        "skipped": skipped_count,
        "non_media": len(non_media) if is_directory else 0,
        "skipped_gifs": len(skipped_gifs),
        "failed_files": failed_files_list,
    }


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Animation‑optimized media compression with HEVC",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  %(prog)s Wa17                              # Process all media in directory
  %(prog)s file1.mov file2.gif               # Process specific files
  %(prog)s Wa17 --no-nvidia                  # Intel only
  %(prog)s Wa17 --no-intel                   # NVIDIA only
  %(prog)s --no-intel --no-nvidia file.mov   # CPU only
  %(prog)s Wa17 --fast-resume                # Skip duration check
  %(prog)s Wa17 -y                           # Skip confirmation
        """,
    )
    parser.add_argument(
        "-y", "--yes", action="store_true", help="Skip confirmation prompt"
    )
    parser.add_argument(
        "--fast-resume",
        action="store_true",
        help="Skip duration verification; skip if output file exists (faster resume)",
    )
    parser.add_argument(
        "inputs",
        nargs="+",
        help="One or more files or directories (if one directory, process all media inside)",
    )
    parser.add_argument(
        "-o", "--output-dir", help="Output directory (only for directory mode)"
    )

    # Worker counts
    parser.add_argument(
        "--nvidia-workers",
        type=int,
        default=DEFAULT_NVIDIA_WORKERS,
        help=f"Number of parallel NVIDIA encoding threads (default: {DEFAULT_NVIDIA_WORKERS})",
    )
    parser.add_argument(
        "--intel-workers",
        type=int,
        default=DEFAULT_INTEL_WORKERS,
        help=f"Number of parallel Intel encoding threads (default: {DEFAULT_INTEL_WORKERS})",
    )
    parser.add_argument(
        "--cpu-workers",
        type=int,
        default=DEFAULT_CPU_WORKERS,
        help=f"Number of parallel CPU encoding threads (default: {DEFAULT_CPU_WORKERS})",
    )

    # Strategy
    parser.add_argument(
        "--strategy",
        choices=["auto", "lossless", "transparent"],
        default="auto",
        help="Encoding strategy (default: auto)",
    )

    # Audio
    parser.add_argument(
        "--audio",
        choices=["copy", "flac", "aac", "opus"],
        default="auto",
        help="Audio handling (default: auto – copy if lossless, opus if lossy)",
    )

    # Quality
    parser.add_argument(
        "--quality",
        type=int,
        default=DEFAULT_QUALITY,
        choices=range(1, 52),
        help=f"Quality level 1-51 (default: {DEFAULT_QUALITY}, lower=better quality)",
    )

    # Force
    parser.add_argument(
        "--force", action="store_true", help="Force re-encode even if output exists"
    )

    # Device enable/disable flags
    parser.add_argument(
        "--nvidia",
        dest="use_nvidia",
        action="store_true",
        default=DEFAULT_USE_NVIDIA,
        help="Enable NVIDIA GPU (default)",
    )
    parser.add_argument(
        "--no-nvidia",
        dest="use_nvidia",
        action="store_false",
        help="Disable NVIDIA GPU",
    )
    parser.add_argument(
        "--intel",
        dest="use_intel",
        action="store_true",
        default=DEFAULT_USE_INTEL,
        help="Enable Intel GPU (default)",
    )
    parser.add_argument(
        "--no-intel",
        dest="use_intel",
        action="store_false",
        help="Disable Intel GPU",
    )

    # Dry run
    parser.add_argument("--dry-run", action="store_true", help="Preview only")

    args = parser.parse_args()

    # Check mutual exclusivity of enable/disable flags
    argv = sys.argv
    if ("--nvidia" in argv and "--no-nvidia" in argv) or (
        "--intel" in argv and "--no-intel" in argv
    ):
        parser.error(
            "Cannot specify both --nvidia and --no-nvidia (or --intel and --no-intel)"
        )

    # Parse inputs
    items, is_directory = build_file_list(args.inputs)

    if is_directory:
        if args.output_dir:
            dst_root = Path(args.output_dir).resolve()
        else:
            dst_root = Path(f"{items[0]}-compressed")
    else:
        if args.output_dir:
            print("Warning: --output-dir is ignored when processing individual files")
        dst_root = None

    if not args.dry_run:
        print("WARNING: This will convert media files:")
        if is_directory:
            print(f"  Source directory: {items[0]}")
            print(f"  Output directory: {dst_root}")
        else:
            print("  Input files:")
            for f in items:
                print(f"    {f}")
            print(
                "  Output: Each file will be saved with '-compressed' suffix in the same directory"
            )
        print(f"\n📊 Strategy: {args.strategy}")
        print(f"📊 Quality: {args.quality} (1=best, 15=transparent, 30=smaller)")
        print(f"🎵 Audio: {args.audio}")
        if args.force:
            print("⚠️ Force re-encode: ON")
        print(
            f"🔄 Workers: NVIDIA={args.nvidia_workers}, Intel={args.intel_workers}, CPU={args.cpu_workers}"
        )
        gpus = check_gpu_availability()
        enabled = []
        if args.use_nvidia and gpus["nvidia"]:
            enabled.append("NVIDIA")
        if args.use_intel and gpus["intel"]:
            enabled.append("Intel")
        if not enabled:
            enabled.append("CPU (fallback)")
        print(f"\n✅ Selected encoders: {', '.join(enabled)}")
        print("✅ Content: Animation (optimized)")
        if not args.yes:
            if not get_user_confirmation("\nContinue? (y/N): "):
                print("Aborted.")
                sys.exit(0)
            print()

    start = time.time()
    force_strat = None if args.strategy == "auto" else args.strategy
    results = process_items(
        items=items,
        dst_root=dst_root,
        dry_run=args.dry_run,
        use_intel=args.use_intel,
        use_nvidia=args.use_nvidia,
        nvidia_workers=args.nvidia_workers,
        intel_workers=args.intel_workers,
        cpu_workers=args.cpu_workers,
        quality=args.quality,
        strategy=force_strat,
        audio=args.audio,
        force=args.force,
        fast_resume=args.fast_resume,
        is_directory=is_directory,
    )
    elapsed = time.time() - start
    print(f"\nTotal time: {elapsed:.2f}s ({elapsed / 60:.1f} minutes)")


if __name__ == "__main__":
    main()
