def convert_with_ffmpeg(
    input_path: Path,
    output_path: Path,
    gpu: str,
    dry_run: bool = False,
    strategy: str = "transparent",
    quality: int = DEFAULT_QUALITY,
    audio_mode: str = "auto",
) -> tuple[bool, str]:
    if dry_run:
        return True, "DRY_RUN"

    try:
        actual_audio, has_audio = _detect_audio(input_path, audio_mode, strategy)
        is_lossless = strategy == "lossless"
        target_quality = 0 if is_lossless else quality

        encoders = _get_encoder_list(gpu, is_lossless)

        for encoder_name, encoder_func in encoders:
            print(f"  Trying {encoder_name}...")
            cmd = encoder_func(
                input_path, output_path, target_quality, has_audio, actual_audio
            )
            print(f"    Running ffmpeg (this may take a while for large files)...")
            print(f"      Command: {' '.join(cmd[:6])}... (truncated)")
            start = time.time()
            result = subprocess.run(
                cmd, capture_output=True, text=True, check=False, timeout=3600
            )
            elapsed = time.time() - start
            print(f"      ffmpeg completed in {elapsed:.2f}s (exit code: {result.returncode})")

            if (
                result.returncode != 0
                or not output_path.exists()
                or output_path.stat().st_size == 0
            ):
                print(f"  ⚠️  {encoder_name} failed. Trying next...")
                if result.stderr:
                    print(f"      Error: {result.stderr[:200]}...")
                continue

            input_size = input_path.stat().st_size
            output_size = output_path.stat().st_size

            if output_size >= input_size:
                print(
                    f"  ⚠️  {encoder_name} output ({output_size / 1024 / 1024:.2f}MB) >= source ({input_size / 1024 / 1024:.2f}MB). Trying next..."
                )
                output_path.unlink(missing_ok=True)
                continue

            reduction = (1 - (output_size / input_size)) * 100
            return (
                True,
                f"{encoder_name}: {input_size / 1024 / 1024:.2f}MB -> {output_size / 1024 / 1024:.2f}MB ({reduction:.1f}% reduction)",
            )

        print(
            "  ⚠️  All encoders failed or produced larger files. Copying original as-is."
        )
        return _copy_fallback(input_path, output_path, has_audio, actual_audio)

    except subprocess.TimeoutExpired:
        return False, "TIMEOUT (1 hour)"
    except Exception as e:
        return False, f"ERROR: {str(e)[:500]}"


def _detect_audio(
    input_path: Path, audio_mode: str, strategy: str
) -> tuple[str | None, bool]:
    has_audio = False
    try:
        print(f"    Checking audio presence with ffprobe: {input_path.name}")
        probe_cmd = [
            "ffprobe",
            "-v",
            "error",
            "-select_streams",
            "a",
            "-show_entries",
            "stream=codec_type",
            "-of",
            "default=noprint_wrappers=1",
            str(input_path),
        ]
        result = subprocess.run(probe_cmd, capture_output=True, text=True, check=False)
        has_audio = "audio" in result.stdout
        print(f"    Audio {'present' if has_audio else 'not present'}")
    except subprocess.SubprocessError:
        pass

    if audio_mode == "auto" and has_audio:
        if strategy == "lossless":
            actual_audio = "copy" if is_audio_lossless(input_path) else "flac"
        else:
            actual_audio = "opus"
    elif not has_audio:
        actual_audio = None
    else:
        actual_audio = audio_mode

    return actual_audio, has_audio


def _get_encoder_list(gpu: str, is_lossless: bool) -> list[tuple[str, callable]]:
    encoders = []
    if gpu == "nvidia":
        encoders.append(("NVIDIA NVENC", _build_nvenc_cmd))
    if gpu in ("intel", "nvidia"):
        encoders.append(("Intel QSV", _build_qsv_cmd))
    if is_lossless:
        encoders.append(("Software HEVC (lossless)", _build_software_lossless_cmd))
    else:
        encoders.append(("Software HEVC", _build_software_lossy_cmd))
    return encoders


def _build_nvenc_cmd(
    input_path: Path,
    output_path: Path,
    quality: int,
    has_audio: bool,
    actual_audio: str | None,
) -> list[str]:
    cmd = [
        "ffmpeg",
        "-i",
        str(input_path),
        "-c:v",
        "hevc_nvenc",
        "-preset",
        "p7",
        "-tune",
        "hq",
        "-rc",
        "vbr",
        "-cq",
        str(quality),
        "-b:v",
        "0",
        "-pix_fmt",
        "yuv420p",
        "-bf",
        "0",
        "-g",
        "99999",
        "-force_key_frames",
        "expr:eq(n,0)",
        "-rc-lookahead",
        "32",
        "-spatial-aq",
        "1",
        "-temporal-aq",
        "1",
        "-loop",
        "0",
        "-y",
        str(output_path),
    ]
    _add_audio_options(cmd, has_audio, actual_audio)
    return cmd


def _build_qsv_cmd(
    input_path: Path,
    output_path: Path,
    quality: int,
    has_audio: bool,
    actual_audio: str | None,
) -> list[str]:
    cmd = [
        "ffmpeg",
        "-i",
        str(input_path),
        "-c:v",
        "hevc_qsv",
        "-preset",
        "veryslow",
        "-global_quality",
        str(quality),
        "-pix_fmt",
        "nv12",
        "-bf",
        "0",
        "-g",
        "99999",
        "-force_key_frames",
        "expr:eq(n,0)",
        "-extbrc",
        "1",
        "-look_ahead",
        "1",
        "-look_ahead_depth",
        "32",
        "-loop",
        "0",
        "-y",
        str(output_path),
    ]
    _add_audio_options(cmd, has_audio, actual_audio)
    return cmd


def _build_software_lossy_cmd(
    input_path: Path,
    output_path: Path,
    quality: int,
    has_audio: bool,
    actual_audio: str | None,
) -> list[str]:
    cmd = [
        "ffmpeg",
        "-i",
        str(input_path),
        "-vf",
        "scale=trunc(iw/2)*2:trunc(ih/2)*2",
        "-c:v",
        "libx265",
        "-crf",
        "18",
        "-pix_fmt",
        "yuv420p",
        "-x265-params",
        "bframes=0:keyint=99999",
        "-force_key_frames",
        "expr:eq(n,0)",
        "-loop",
        "0",
        "-y",
        str(output_path),
    ]
    _add_audio_options(cmd, has_audio, actual_audio)
    return cmd


def _build_software_lossless_cmd(
    input_path: Path,
